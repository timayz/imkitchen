# ImKitchen Environment Configuration
# Copy this file to .env and update the values for your environment

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/imkitchen_dev

# Redis Configuration  
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_in_production_min_32_chars

# Application Environment
ENVIRONMENT=development
RUST_LOG=debug,tower_http=debug,sqlx=info

# External Service Configuration
# VAPID Keys for Push Notifications (generate using web-push CLI)
# VAPID_PRIVATE_KEY=
# VAPID_PUBLIC_KEY=

# File Storage Configuration
# UPLOAD_PATH=./uploads
# MAX_FILE_SIZE=10485760

# Email Configuration (for password reset, etc.)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# FROM_EMAIL=noreply@imkitchen.local

# Recipe Import Configuration
# USER_AGENT=ImKitchen/1.0 Recipe Importer

# Development/Testing Configuration
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/imkitchen_test

# Production-specific Configuration
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem