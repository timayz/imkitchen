// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Household model for shared kitchen spaces
model Household {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(255)
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  users           User[]
  inventoryItems  InventoryItem[]
  customCategories CustomCategory[]

  // Indexes for performance optimization
  @@index([createdAt], name: "idx_households_created_at")
  @@map("households")
}

// Enum for dietary preferences
enum DietaryPreference {
  VEGETARIAN
  VEGAN
  KETO
  PALEO
  GLUTEN_FREE
  DAIRY_FREE

  @@map("dietary_preference")
}

// Enum for supported languages
enum Language {
  EN
  ES
  FR
  DE

  @@map("language")
}

// User model for authentication and user management
model User {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String              @unique @db.VarChar(255)
  name              String              @db.VarChar(255)
  passwordHash      String              @map("password_hash") @db.VarChar(255)
  dietaryPreferences DietaryPreference[] @map("dietary_preferences")
  allergies         String[]
  householdId       String              @map("household_id") @db.Uuid
  language          Language            @default(EN)
  timezone          String              @default("UTC") @db.VarChar(50)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  household           Household           @relation(fields: [householdId], references: [id])
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  inventoryItems      InventoryItem[]
  customCategories    CustomCategory[]

  // Indexes for performance optimization
  @@index([householdId], name: "idx_users_household_id")
  @@index([createdAt], name: "idx_users_created_at")
  @@map("users")
}

// Session model for authentication state management
model Session {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  token       String   @unique @db.VarChar(500)
  expiresAt   DateTime @map("expires_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes for performance optimization
  @@index([userId], name: "idx_sessions_user_id")
  @@index([expiresAt], name: "idx_sessions_expires_at")
  @@map("sessions")
}

// Password reset token model for password reset functionality
model PasswordResetToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes for performance optimization
  @@index([userId], name: "idx_password_reset_tokens_user_id")
  @@index([token], name: "idx_password_reset_tokens_token")
  @@index([expiresAt], name: "idx_password_reset_tokens_expires_at")
  @@map("password_reset_tokens")
}

// Enums for inventory management
enum StorageLocation {
  pantry
  refrigerator  
  freezer

  @@map("storage_location")
}

enum InventoryCategory {
  proteins
  vegetables
  fruits
  grains
  dairy
  spices
  condiments
  beverages
  baking
  frozen

  @@map("inventory_category")
}

// Custom category model for household-specific categories
model CustomCategory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(50)
  color       String   @db.VarChar(7) // Hex color code
  icon        String   @db.VarChar(50)
  householdId String   @map("household_id") @db.Uuid
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  household Household @relation(fields: [householdId], references: [id])
  createdByUser User @relation(fields: [createdBy], references: [id])

  // Unique constraint for name per household
  @@unique([name, householdId], name: "unique_category_name_per_household")
  @@index([householdId], name: "idx_custom_categories_household")
  @@map("custom_categories")
}

// Inventory management model
model InventoryItem {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String            @db.VarChar(255)
  quantity       Decimal           @db.Decimal(10, 2)
  unit           String            @db.VarChar(50)
  category       String            @db.VarChar(50) // Can be InventoryCategory enum value or CustomCategory.id
  location       StorageLocation
  expirationDate DateTime?         @map("expiration_date") @db.Date
  purchaseDate   DateTime?         @default(now()) @map("purchase_date") @db.Date
  estimatedCost  Decimal?          @map("estimated_cost") @db.Decimal(10, 2)
  householdId    String            @map("household_id") @db.Uuid
  addedBy        String            @map("added_by") @db.Uuid
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  household Household @relation(fields: [householdId], references: [id])
  addedByUser User @relation(fields: [addedBy], references: [id])

  // Indexes for performance optimization
  @@index([householdId, location], name: "idx_inventory_household_location")
  @@index([householdId, category], name: "idx_inventory_household_category")
  @@index([expirationDate], name: "idx_inventory_expiration")
  @@map("inventory_items")
}
